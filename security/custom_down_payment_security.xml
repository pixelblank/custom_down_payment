<odoo>
    <data noupdate="1">
        <!-- Définir les groupes d'utilisateurs si nécessaire -->
        <record id="group_custom_down_payment_user" model="res.groups">
            <field name="name">Custom Down Payment User</field>
            <field name="category_id" ref="base.module_category_accounting_accounting"/>
        </record>

        <!-- Définir les règles d'accès si nécessaire -->
        <record id="rule_custom_down_payment" model="ir.rule">
            <field name="name">Custom Down Payment Rule</field>
            <field name="model_id" ref="model_account_move"/>
            <field name="domain_force">[]</field>
            <field name="groups" eval="[(4, ref('group_custom_down_payment_user'))]"/>
        </record>
    </data>
</odoo>
