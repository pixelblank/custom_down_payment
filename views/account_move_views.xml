<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_move_form_inherit_custom_down_payment" model="ir.ui.view">
            <field name="name">account.move.form.inherit.custom.down.payment</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='payment_reference']" position="after">
                    <field name="product_names" attrs="{'invisible': [('move_type', '!=', 'out_invoice')]}" widget="text"/>
                    <field name="debug_info" attrs="{'invisible': [('move_type', '!=', 'out_invoice')]}" widget="text"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>